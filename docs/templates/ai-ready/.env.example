# Environment template
# Copy this file to .env.local/.env and fill values for your environment.

# App
APP_ENV=local
APP_PORT=3000
APP_BASE_URL=http://localhost:3000

# API / Backend
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT_MS=10000

# Feature flags
FEATURE_EXPERIMENTAL=0
FEATURE_VERBOSE_LOGS=0

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=1

# Storage
STORAGE_MODE=local
DATABASE_URL=

# External providers (set only when needed)
AI_PROVIDER=
AI_API_KEY=
PUSH_PROVIDER=
PUSH_API_KEY=

# Notes
# - Never commit real secrets.
# - Keep production values in secret manager/CI variables.
